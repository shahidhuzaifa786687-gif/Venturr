# Public browser configuration. Use a different Supabase project for local,
# preview, and production environments.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
VITE_GOOGLE_AUTH_ENABLED=false

# Never put SUPABASE_SECRET_KEY, service_role, database passwords, SMTP
# credentials, or CAPTCHA secrets in a VITE_ variable.
